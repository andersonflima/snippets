{
  "name": "aws-resource-control-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace @platform/backend run dev",
    "dev:frontend": "npm --workspace @platform/frontend run start",
    "build": "npm-run-all build:shared build:backend build:frontend",
    "build:shared": "npm --workspace @platform/shared run build",
    "build:backend": "npm --workspace @platform/backend run build",
    "build:frontend": "npm --workspace @platform/frontend run build",
    "typecheck": "npm-run-all typecheck:*",
    "typecheck:shared": "npm --workspace @platform/shared run build",
    "typecheck:backend": "npm --workspace @platform/backend run typecheck",
    "typecheck:frontend": "npm --workspace @platform/frontend run typecheck"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "~5.5.4"
  }
}
