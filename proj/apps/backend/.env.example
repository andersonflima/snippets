PORT=3000
JWT_SECRET=troque-este-segredo
DATABASE_URL=postgres://platform:platform@localhost:5432/platform
DATABASE_SSL=false
AWS_EXTERNAL_ID=
# Opcional: quando definido, o backend usa AssumeRole.
# AWS_ASSUME_ROLE_ARN_TEMPLATE=arn:aws:iam::{account_id}:role/PlatformAssumeRole
# Opcional: endpoint AWS customizado. Para LocalStack local use http://localhost:4566.
# AWS_ENDPOINT_URL=http://localhost:4566
# Opcional: no LocalStack multi-account, usa o accountId selecionado como access key
# de origem para assumir a role na mesma namespace da conta.
AWS_USE_ACCOUNT_ID_FOR_LOCALSTACK=true
# Opcional: arquivo com contas seed gerado pelo provisionamento do LocalStack Pro.
# PLATFORM_SEED_ACCOUNTS_FILE=
# Opcional: modo de TLS inseguro para troubleshooting de certificado no ambiente local.
AWS_TLS_INSECURE=false
# Credenciais AWS opcionais (diretas). Se omitidas, usa cadeia padrao do SDK.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
